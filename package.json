{
  "name": "@webwaka/services",
  "version": "0.1.0",
  "description": "WebWaka Services Suite — Consulting, Freelancing, and Agencies on WebWaka OS v4",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8000",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@webwaka/core": "^1.6.1",
    "dexie": "^4.4.2",
    "hono": "^4.12.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.80.0"
  }
}
